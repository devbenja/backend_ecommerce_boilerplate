generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  role         Role     @default(USER)
  password     String
  status       Boolean  @default(true)
  date_created DateTime @default(now())
  date_updated DateTime @updatedAt

  @@map("users")
}
 
enum Role {
  ADMIN
  USER
}